# =============================================================================
# GetDriver - Environment Variables
# =============================================================================
# Bu dosyayı kopyalayarak .env.local oluşturun:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Veritabanı (PostgreSQL)
# -----------------------------------------------------------------------------
# Örnek: postgresql://user:password@host:5432/dbname?connect_timeout=15
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?connect_timeout=15"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# Üretim URL'si (Vercel deploy sonrası güncelleyin)
NEXTAUTH_URL="https://www.getdriver.com.tr"

# Güçlü rastgele string (üretmek için: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials adresinden alın
# Authorized redirect URI: https://[domain]/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# Google Maps API
# -----------------------------------------------------------------------------
# Google Cloud Console → Maps JavaScript API / Directions API / Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# -----------------------------------------------------------------------------
# AWS S3 (Dosya yükleme)
# -----------------------------------------------------------------------------
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="your-s3-bucket-name"
AWS_FOLDER_PREFIX="uploads/"
# IAM kullanıcısı için Access Key (veya Vercel'de IAM role kullanın)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# -----------------------------------------------------------------------------
# Firebase Admin SDK (Bildirimler - Sunucu tarafı)
# -----------------------------------------------------------------------------
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID="getdriver-b3f3b"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@getdriver-b3f3b.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Web Push Bildirimleri (VAPID)
# -----------------------------------------------------------------------------
# Üretmek için: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# -----------------------------------------------------------------------------
# İleti Merkezi (SMS - OTP için)
# -----------------------------------------------------------------------------
ILETIMERKEZI_API_KEY="your-iletimerkezi-api-key"
ILETIMERKEZI_API_HASH="your-iletimerkezi-api-hash"
ILETIMERKEZI_SENDER_ID="getdriver"

# -----------------------------------------------------------------------------
# AbacusAI (Opsiyonel - AI özellikleri için)
# -----------------------------------------------------------------------------
ABACUSAI_API_KEY="your-abacusai-api-key"

# -----------------------------------------------------------------------------
# Uygulama ID'leri (Bildirim sistemi)
# -----------------------------------------------------------------------------
WEB_APP_ID="your-web-app-id"
NOTIF_ID_YENI_TEKLIF_BILDIRIMI="your-notification-id"

# -----------------------------------------------------------------------------
# PayTR Ödeme Sistemi
# -----------------------------------------------------------------------------
PAYTR_MERCHANT_ID="your-paytr-merchant-id"
PAYTR_MERCHANT_KEY="your-paytr-merchant-key"
PAYTR_MERCHANT_SALT="your-paytr-merchant-salt"
PAYTR_TEST_MODE="1"  # 1 = Test modu, 0 = Canlı mod
